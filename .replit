modules = ["web", "nodejs-20", "python-3.12", "postgresql-16"]
[agent]
expertMode = true
integrations = ["stripe:2.0.0", "javascript_object_storage:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CRM Backend"

[[workflows.workflow]]
name = "CRM Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"metro2 (copy 1)/crm\" && PORT=5000 npm run dev"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd 'metro2 (copy 1)/crm' && NODE_ENV=production node server.js"]
build = ["bash", "-c", "cd 'metro2 (copy 1)/crm' && npm install"]

[userenv]

[userenv.production]
JWT_SECRET = "evolve-ai-production-jwt-secret-2026"
NODE_ENV = "production"
DATABASE_CLIENT = "pg"
DIY_JWT_SECRET = "8ccead28fbe396fd260521e06155f137ef6645801e8b0a206a5ad0276908576f"

[userenv.shared]

[userenv.development]
JWT_SECRET = "2801fa1455d869a0a935459673805cbe5be2d8c4405c6b075b912835e73dde80"
DIY_JWT_SECRET = "84683f81b4a9eb706c060d654b6c8920a6a680129821719d763be55bc84067a0"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
