{
  "name": "metro2-crm",
  "version": "1.0.0",
  "description": "Minimal CRM to select Metro 2 violations and generate dispute letters",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --import tsx/esm server.js",
    "dev": "NODE_ENV=development node --import tsx/esm server.js",
    "build": "vite build --config vite.config.ts",
    "typecheck": "tsc --noEmit",
    "audit": "node creditAuditTool.js",
    "postinstall": "if [ \"$NODE_ENV\" != \"production\" ] && [ \"$SKIP_PYTHON_SETUP\" != \"true\" ]; then node ./scripts/setupPythonEnv.js || true; fi",
    "test": "node --import tsx/esm --test tests/*.test.js",
    "marketing:twilio-worker": "node --import tsx/esm scripts/marketingTwilioWorker.js",
    "setup:chrome": "bash install-chrome-deps.sh",
    "migrate": "node --import tsx/esm scripts/runMigrations.js",
    "generate:rule-report": "node --import tsx/esm scripts/generateRuleTestReport.js",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@tanstack/react-query": "^5.96.1",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.17.1",
    "archiver": "^6.0.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.61.0",
    "cheerio": "^1.1.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.1",
    "jsdom": "^24.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "lodash": "^4.17.23",
    "multer": "^2.1.1",
    "mysql2": "^3.9.7",
    "nanoid": "^5.1.5",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.11",
    "openai": "^4.104.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.5",
    "puppeteer": "^24.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "sqlite3": "^5.1.7",
    "stripe": "^18.5.0",
    "twilio": "^4.22.0",
    "zipcodes": "^8.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "glob": "^13.0.6",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
